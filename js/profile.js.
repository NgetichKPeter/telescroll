const {
    data: { user }
} = await supabase.auth.getUser();

console.log("User:", user);

if (!user) {
    alert("No user logged in.");
    window.location.href = "auth.html";
    return;
}

const { data: profile, error } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", user.id)
    .single();

console.log("Profile:", profile);
console.log("Error:", error);